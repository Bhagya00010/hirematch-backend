    {
      "name": "ATS",
      "item": [
        {
          "name": "Get ATS Config",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is valid ATS config', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('company_id');",
                  "  pm.expect(json).to.have.property('config_name', 'default');",
                  "  pm.expect(json).to.have.property('weight_must_have');",
                  "  pm.expect(json).to.have.property('retrieval_top_n');",
                  "  pm.expect(json).to.have.property('llm_weight');",
                  "  pm.collectionVariables.set('ats_config_id', json.id);",
                  "  pm.collectionVariables.set('company_id', json.company_id);",
                  "});",
                  "",
                  "pm.test('ATS weights total 1.000', function () {",
                  "  const json = pm.response.json();",
                  "  const total = Number(json.weight_must_have)",
                  "    + Number(json.weight_semantic)",
                  "    + Number(json.weight_project_impact)",
                  "    + Number(json.weight_domain)",
                  "    + Number(json.weight_education);",
                  "  pm.expect(Math.round(total * 1000) / 1000).to.eql(1.0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/ats",
              "host": ["{{base_url}}"],
              "path": ["ats"]
            },
            "description": "Returns the current user's ATS config. Creates default config on first call."
          },
